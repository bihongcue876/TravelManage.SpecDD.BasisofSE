[run]
source = .
omit =
    tests/*
    */__pycache__/*
    */__init__.py
    test_new_features.py
    services/pdf_generator.py
    tasks_scheduler.py
    routers/tasks.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    pass

[html]
directory = htmlcov
